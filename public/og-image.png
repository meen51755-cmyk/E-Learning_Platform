<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630" width="1200" height="630">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a1a2e"/>
      <stop offset="100%" style="stop-color:#16213e"/>
    </linearGradient>
    <linearGradient id="accent" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#6366f1"/>
      <stop offset="100%" style="stop-color:#8b5cf6"/>
    </linearGradient>
    <linearGradient id="glow" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#6366f1;stop-opacity:0.3"/>
      <stop offset="100%" style="stop-color:#8b5cf6;stop-opacity:0"/>
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect width="1200" height="630" fill="url(#bg)"/>

  <!-- Glow circles -->
  <circle cx="200" cy="150" r="300" fill="url(#glow)" opacity="0.5"/>
  <circle cx="1000" cy="480" r="250" fill="url(#glow)" opacity="0.4"/>

  <!-- Grid pattern -->
  <g opacity="0.05" stroke="#ffffff" stroke-width="1">
    <line x1="0" y1="105" x2="1200" y2="105"/>
    <line x1="0" y1="210" x2="1200" y2="210"/>
    <line x1="0" y1="315" x2="1200" y2="315"/>
    <line x1="0" y1="420" x2="1200" y2="420"/>
    <line x1="0" y1="525" x2="1200" y2="525"/>
    <line x1="150" y1="0" x2="150" y2="630"/>
    <line x1="300" y1="0" x2="300" y2="630"/>
    <line x1="450" y1="0" x2="450" y2="630"/>
    <line x1="600" y1="0" x2="600" y2="630"/>
    <line x1="750" y1="0" x2="750" y2="630"/>
    <line x1="900" y1="0" x2="900" y2="630"/>
    <line x1="1050" y1="0" x2="1050" y2="630"/>
  </g>

  <!-- Logo box -->
  <rect x="80" y="80" width="80" height="80" rx="20" fill="url(#accent)"/>
  <text x="120" y="137" font-family="Georgia, serif" font-size="44" font-weight="900" fill="white" text-anchor="middle">L</text>

  <!-- Brand name -->
  <text x="180" y="112" font-family="Georgia, serif" font-size="42" font-weight="700" fill="white">LearnHub</text>
  <text x="180" y="148" font-family="Arial, sans-serif" font-size="20" fill="#94a3b8">แพลตฟอร์มเรียนออนไลน์</text>

  <!-- Divider line -->
  <rect x="80" y="200" width="120" height="4" rx="2" fill="url(#accent)"/>

  <!-- Main headline -->
  <text x="80" y="290" font-family="Georgia, serif" font-size="64" font-weight="900" fill="white">เรียนรู้ทักษะใหม่ๆ</text>
  <text x="80" y="370" font-family="Georgia, serif" font-size="64" font-weight="900" fill="white">กับผู้เชี่ยวชาญจริง</text>

  <!-- Subtitle -->
  <text x="80" y="430" font-family="Arial, sans-serif" font-size="26" fill="#94a3b8">คอร์สออนไลน์คุณภาพสูง • เรียนได้ทุกที่ทุกเวลา</text>

  <!-- Stats -->
  <g transform="translate(80, 490)">
    <!-- Stat 1 -->
    <rect x="0" y="0" width="220" height="90" rx="12" fill="white" opacity="0.05"/>
    <text x="110" y="38" font-family="Arial, sans-serif" font-size="30" font-weight="800" fill="white" text-anchor="middle">45,000+</text>
    <text x="110" y="68" font-family="Arial, sans-serif" font-size="16" fill="#94a3b8" text-anchor="middle">ผู้เรียน</text>
    <!-- Stat 2 -->
    <rect x="240" y="0" width="220" height="90" rx="12" fill="white" opacity="0.05"/>
    <text x="350" y="38" font-family="Arial, sans-serif" font-size="30" font-weight="800" fill="white" text-anchor="middle">320+</text>
    <text x="350" y="68" font-family="Arial, sans-serif" font-size="16" fill="#94a3b8" text-anchor="middle">คอร์ส</text>
    <!-- Stat 3 -->
    <rect x="480" y="0" width="220" height="90" rx="12" fill="white" opacity="0.05"/>
    <text x="590" y="38" font-family="Arial, sans-serif" font-size="30" font-weight="800" fill="white" text-anchor="middle">4.8 ⭐</text>
    <text x="590" y="68" font-family="Arial, sans-serif" font-size="16" fill="#94a3b8" text-anchor="middle">คะแนนเฉลี่ย</text>
  </g>

  <!-- Right side decorative card -->
  <rect x="820" y="180" width="300" height="380" rx="20" fill="white" opacity="0.04" stroke="white" stroke-opacity="0.1" stroke-width="1"/>
  <rect x="840" y="210" width="260" height="140" rx="12" fill="url(#accent)" opacity="0.3"/>
  <text x="970" y="270" font-family="Arial, sans-serif" font-size="18" fill="white" text-anchor="middle" opacity="0.8">Complete Web Dev</text>
  <text x="970" y="300" font-family="Arial, sans-serif" font-size="14" fill="#94a3b8" text-anchor="middle">120 บทเรียน • 42 ชม.</text>
  <!-- Progress bar -->
  <rect x="840" y="320" width="260" height="8" rx="4" fill="white" opacity="0.1"/>
  <rect x="840" y="320" width="140" height="8" rx="4" fill="url(#accent)"/>
  <text x="970" y="360" font-family="Arial, sans-serif" font-size="13" fill="#94a3b8" text-anchor="middle">54% เรียนแล้ว</text>

  <rect x="840" y="380" width="260" height="60" rx="12" fill="white" opacity="0.04" stroke="white" stroke-opacity="0.1" stroke-width="1"/>
  <text x="970" y="418" font-family="Arial, sans-serif" font-size="15" fill="white" text-anchor="middle" opacity="0.7">Data Science with Python</text>

  <rect x="840" y="455" width="260" height="60" rx="12" fill="white" opacity="0.04" stroke="white" stroke-opacity="0.1" stroke-width="1"/>
  <text x="970" y="493" font-family="Arial, sans-serif" font-size="15" fill="white" text-anchor="middle" opacity="0.7">UI/UX Design Masterclass</text>

  <!-- Bottom accent line -->
  <rect x="0" y="620" width="1200" height="10" fill="url(#accent)"/>
</svg>
