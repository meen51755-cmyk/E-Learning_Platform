<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630" width="1200" height="630">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0f0f1a"/>
      <stop offset="100%" style="stop-color:#1a1035"/>
    </linearGradient>
    <linearGradient id="accent" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#6366f1"/>
      <stop offset="100%" style="stop-color:#8b5cf6"/>
    </linearGradient>
    <linearGradient id="card" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#ffffff;stop-opacity:0.07"/>
      <stop offset="100%" style="stop-color:#ffffff;stop-opacity:0.02"/>
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect width="1200" height="630" fill="url(#bg)"/>

  <!-- Glow blobs -->
  <circle cx="150" cy="200" r="280" fill="#6366f1" opacity="0.12"/>
  <circle cx="1050" cy="430" r="220" fill="#8b5cf6" opacity="0.10"/>
  <circle cx="600" cy="630" r="200" fill="#6366f1" opacity="0.07"/>

  <!-- Subtle dot grid -->
  <pattern id="dots" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
    <circle cx="2" cy="2" r="1" fill="white" opacity="0.08"/>
  </pattern>
  <rect width="1200" height="630" fill="url(#dots)"/>

  <!-- ── Logo area ── -->
  <rect x="72" y="72" width="72" height="72" rx="18" fill="url(#accent)"/>
  <!-- L letter -->
  <rect x="94" y="92" width="10" height="40" rx="3" fill="white"/>
  <rect x="94" y="122" width="28" height="10" rx="3" fill="white"/>

  <text x="162" y="106" font-family="Georgia, 'Times New Roman', serif" font-size="36" font-weight="700" fill="white" letter-spacing="1">LearnHub</text>
  <text x="164" y="132" font-family="Arial, sans-serif" font-size="15" fill="#818cf8" letter-spacing="3">ONLINE LEARNING PLATFORM</text>

  <!-- Divider -->
  <rect x="72" y="178" width="100" height="3" rx="2" fill="url(#accent)"/>
  <rect x="182" y="179" width="40" height="1" rx="1" fill="#6366f1" opacity="0.4"/>

  <!-- ── Main headline ── -->
  <text x="72" y="262" font-family="Georgia, 'Times New Roman', serif" font-size="68" font-weight="900" fill="white" letter-spacing="-1">Learn Skills</text>
  <text x="72" y="342" font-family="Georgia, 'Times New Roman', serif" font-size="68" font-weight="900" letter-spacing="-1">
    <tspan fill="#6366f1">From</tspan>
    <tspan fill="white"> Experts</tspan>
  </text>

  <!-- Subtitle -->
  <text x="72" y="396" font-family="Arial, sans-serif" font-size="22" fill="#94a3b8" letter-spacing="0.5">High-quality online courses · Learn anytime, anywhere</text>

  <!-- ── Stat cards ── -->
  <!-- Card 1 -->
  <rect x="72" y="440" width="200" height="88" rx="14" fill="url(#card)" stroke="white" stroke-opacity="0.08" stroke-width="1"/>
  <text x="172" y="482" font-family="Georgia, serif" font-size="34" font-weight="800" fill="white" text-anchor="middle">45K+</text>
  <text x="172" y="510" font-family="Arial, sans-serif" font-size="14" fill="#818cf8" text-anchor="middle" letter-spacing="1">STUDENTS</text>

  <!-- Card 2 -->
  <rect x="290" y="440" width="200" height="88" rx="14" fill="url(#card)" stroke="white" stroke-opacity="0.08" stroke-width="1"/>
  <text x="390" y="482" font-family="Georgia, serif" font-size="34" font-weight="800" fill="white" text-anchor="middle">320+</text>
  <text x="390" y="510" font-family="Arial, sans-serif" font-size="14" fill="#818cf8" text-anchor="middle" letter-spacing="1">COURSES</text>

  <!-- Card 3 -->
  <rect x="508" y="440" width="200" height="88" rx="14" fill="url(#card)" stroke="white" stroke-opacity="0.08" stroke-width="1"/>
  <text x="608" y="482" font-family="Georgia, serif" font-size="34" font-weight="800" fill="white" text-anchor="middle">4.8 ★</text>
  <text x="608" y="510" font-family="Arial, sans-serif" font-size="14" fill="#818cf8" text-anchor="middle" letter-spacing="1">RATING</text>

  <!-- ── Right side course preview ── -->
  <rect x="790" y="160" width="338" height="400" rx="20" fill="url(#card)" stroke="white" stroke-opacity="0.08" stroke-width="1"/>

  <!-- Course card 1 (featured) -->
  <rect x="808" y="178" width="302" height="158" rx="14" fill="url(#accent)" opacity="0.85"/>
  <rect x="808" y="178" width="302" height="158" rx="14" fill="black" opacity="0.15"/>
  <text x="960" y="240" font-family="Arial, sans-serif" font-size="11" fill="white" text-anchor="middle" opacity="0.7" letter-spacing="2">WEB DEVELOPMENT</text>
  <text x="960" y="268" font-family="Georgia, serif" font-size="20" font-weight="700" fill="white" text-anchor="middle">Complete Web Dev</text>
  <text x="960" y="292" font-family="Arial, sans-serif" font-size="13" fill="white" text-anchor="middle" opacity="0.7">120 lessons · 42 hours</text>
  <!-- Progress -->
  <rect x="826" y="310" width="266" height="6" rx="3" fill="white" opacity="0.2"/>
  <rect x="826" y="310" width="144" height="6" rx="3" fill="white" opacity="0.9"/>
  <text x="960" y="330" font-family="Arial, sans-serif" font-size="12" fill="white" text-anchor="middle" opacity="0.6">54% complete</text>

  <!-- Course card 2 -->
  <rect x="808" y="352" width="302" height="60" rx="12" fill="white" opacity="0.04" stroke="white" stroke-opacity="0.06" stroke-width="1"/>
  <rect x="820" y="367" width="36" height="36" rx="8" fill="#6366f1" opacity="0.5"/>
  <text x="838" y="390" font-family="Arial, sans-serif" font-size="13" fill="white" text-anchor="middle" opacity="0.5">DS</text>
  <text x="870" y="378" font-family="Arial, sans-serif" font-size="14" fill="white" opacity="0.8">Data Science Python</text>
  <text x="870" y="398" font-family="Arial, sans-serif" font-size="12" fill="#818cf8">Beginner · Free</text>

  <!-- Course card 3 -->
  <rect x="808" y="426" width="302" height="60" rx="12" fill="white" opacity="0.04" stroke="white" stroke-opacity="0.06" stroke-width="1"/>
  <rect x="820" y="441" width="36" height="36" rx="8" fill="#8b5cf6" opacity="0.5"/>
  <text x="838" y="464" font-family="Arial, sans-serif" font-size="13" fill="white" text-anchor="middle" opacity="0.5">UX</text>
  <text x="870" y="452" font-family="Arial, sans-serif" font-size="14" fill="white" opacity="0.8">UI/UX Design Master</text>
  <text x="870" y="472" font-family="Arial, sans-serif" font-size="12" fill="#818cf8">Intermediate · ฿990</text>

  <!-- Course card 4 -->
  <rect x="808" y="500" width="302" height="50" rx="12" fill="white" opacity="0.04" stroke="white" stroke-opacity="0.06" stroke-width="1"/>
  <rect x="820" y="513" width="36" height="28" rx="8" fill="#10b981" opacity="0.4"/>
  <text x="838" y="532" font-family="Arial, sans-serif" font-size="11" fill="white" text-anchor="middle" opacity="0.5">AI</text>
  <text x="870" y="526" font-family="Arial, sans-serif" font-size="14" fill="white" opacity="0.8">AI &amp; Machine Learning</text>
  <text x="870" y="543" font-family="Arial, sans-serif" font-size="12" fill="#818cf8">Advanced · ฿1,290</text>

  <!-- Bottom bar -->
  <rect x="0" y="618" width="1200" height="12" fill="url(#accent)"/>
</svg>
